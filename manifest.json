{
  "manifest_version": 3,
  "name": "小红书笔记一键复制",
  "version": "1.0.0",
  "description": "在小红书笔记详情页添加一键复制按钮，快速复制笔记标题、正文、标签和作者",
  "permissions": ["activeTab", "scripting", "storage"],
  "host_permissions": [
    "https://www.xiaohongshu.com/*"
  ],
  "action": {
    "default_popup": "popup.html",
    "default_icon": {
      "16": "icons/icon16.png",
      "48": "icons/icon48.png",
      "128": "icons/icon128.png"
    }
  },
  "content_scripts": [
    {
      "matches": [
        "https://www.xiaohongshu.com/*"
      ],
      "js": ["content.js"],
      "css": ["styles.css"],
      "run_at": "document_idle"
    }
  ],
  "icons": {
    "16": "icons/icon16.png",
    "48": "icons/icon48.png",
    "128": "icons/icon128.png"
  }
}
